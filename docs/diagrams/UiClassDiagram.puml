@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor UI_COLOR_T4
skinparam classBackgroundColor UI_COLOR

package UI <<Rectangle>>{
Class "<<interface>>\nUi" as Ui
Class "{abstract}\nUiPart" as UiPart
Class UiManager
Class MainWindow
Class HelpWindow
Class ResultHistory
Class PersonListPanel
Class PersonCard
Class PersonDetailPanel
Class CommandBox
Class SetupPanel
}

package Model <<Rectangle>> {
Class HiddenModel #FFFFFF
}

package Logic <<Rectangle>> {
Class HiddenLogic #FFFFFF
}

package Security <<Rectangle>> {
Class HiddenSecurity #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Ui

UiManager .left.|> Ui
UiManager -down-> "1" MainWindow
MainWindow *-down->  "1" CommandBox
MainWindow *-down-> "1" ResultHistory
MainWindow *-down-> "1" PersonListPanel
MainWindow *-down-> "1" PersonDetailPanel
MainWindow *-down-> "1" HelpWindow
MainWindow *-down-> "1" SetupPanel

PersonListPanel -down-> "*" PersonCard

MainWindow -left-|> UiPart

ResultHistory --|> UiPart
CommandBox --|> UiPart
PersonListPanel --|> UiPart
PersonCard --|> UiPart
PersonDetailPanel --|> UiPart
HelpWindow --|> UiPart
SetupPanel --|> UiPart

PersonCard ..> Model
PersonDetailPanel ..> Model
UiManager -right-> Logic
MainWindow -left-> Logic
UiManager -up-> Security
MainWindow -right-> Security

PersonDetailPanel -[hidden]left- PersonListPanel
PersonListPanel -[hidden]left- CommandBox
CommandBox -[hidden]left- ResultHistory
HelpWindow -[hidden]left- PersonDetailPanel
SetupPanel -[hidden]left- HelpWindow

MainWindow -[hidden]-|> UiPart
@enduml
